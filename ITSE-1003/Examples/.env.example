# -------------------------------------------------
# File Name: .env.example
# Author: Florentino
# Date: 3/21/26
# Description: Environment variables template for database configurations.
#              Copy to .env in this folder (same directory as database_config.py).
#              database_config.py loads .env via python-dotenv.
# -------------------------------------------------

# Database Configuration
# =====================

# SQLite Database (Default - No installation required)
DB_TYPE=sqlite
DB_HOST=localhost
DB_PORT=5432
DB_NAME=school.db
DB_USER=
DB_PASSWORD=
DB_SSL_MODE=disable

# PostgreSQL Configuration
# =====================
# DB_TYPE=postgresql
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=school_db
# DB_USER=postgres
# DB_PASSWORD=your_password
# DB_SSL_MODE=require

# MySQL Configuration
# ==================
# DB_TYPE=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=school_db
# DB_USER=root
# DB_PASSWORD=your_mysql_password
# DB_SSL_MODE=disable

# SQL Server Configuration
# =======================
# DB_TYPE=mssql
# DB_HOST=localhost
# DB_PORT=1433
# DB_NAME=school_db
# DB_USER=sa
# DB_PASSWORD=your_sql_server_password
# DB_SSL_MODE=require

# Database Connection Settings
# ===========================
DB_TIMEOUT=30
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=3600
DB_ECHO=false

# SQLAlchemy Configuration
# ========================
# If you build URLs by hand, use an absolute path or run from Examples/ with data/school.db.
# database_config.py resolves DB_NAME=school.db to Examples/data/school.db automatically.
SQLALCHEMY_DATABASE_URL=sqlite:///data/school.db
SQLALCHEMY_TRACK_MODIFICATIONS=false
SQLALCHEMY_ECHO=false

# Application Settings
# ===================
APP_NAME=ITSE-1003 Examples
APP_VERSION=1.0.0
DEBUG=true
LOG_LEVEL=INFO

# File Paths
# ==========
DATA_DIR=data
GEN_DIR=data/generated
EXPORT_DIR=data/exports
BACKUP_DIR=data/backups

# CSV Configuration
# =================
# Quoted values so python-dotenv parses correctly (comma and " are special).
CSV_DELIMITER=","
CSV_QUOTECHAR="\""
CSV_ENCODING=utf-8
CSV_LINE_TERMINATOR="\n"

# Security Settings
# =================
SECRET_KEY=your-secret-key-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# API Configuration
# =================
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Cache Configuration
# ===================
CACHE_TYPE=simple
CACHE_DEFAULT_TIMEOUT=300
CACHE_DIR=data/cache

# Email Configuration (Optional)
# ==============================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_TLS=true
SMTP_SSL=false

# Development Settings
# ====================
DEVELOPMENT=true
TESTING=false
PRODUCTION=false

# Logging Configuration
# =====================
LOG_FILE=logs/app.log
LOG_MAX_SIZE=10485760
LOG_BACKUP_COUNT=5
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# Performance Settings
# ====================
MAX_WORKERS=4
BATCH_SIZE=1000
QUERY_TIMEOUT=30
CONNECTION_POOL_SIZE=20

# Feature Flags
# =============
ENABLE_DATABASE_LOGGING=false
ENABLE_QUERY_CACHE=true
ENABLE_CONNECTION_POOLING=true
ENABLE_ASYNC_QUERIES=false

# Monitoring
# ===========
ENABLE_METRICS=true
METRICS_PORT=9090
HEALTH_CHECK_INTERVAL=30
