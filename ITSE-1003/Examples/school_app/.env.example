# Database Configuration
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/school_db

# Alternative database configurations:
# PostgreSQL: postgresql+psycopg2://user:password@localhost:5432/school_db
# SQLite: sqlite:///./school.db

# Application Settings
APP_NAME="School Management API"
DEBUG=true
LOG_LEVEL=INFO

# Security
SECRET_KEY=your-secret-key-change-in-production

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
